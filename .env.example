# ============================================================
# .env.example — 所有需要的环境变量
# 复制为 .env 并填写你自己的值
# ============================================================

# Gmail（用于 send_email / crontab_monitor 告警邮件）
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENTS=

# AI agent backend（供 Codex automation 和手动补跑脚本共用）
AI_HEARTBEAT_BACKEND=codex

# Codex CLI（主路径：供 Codex automation 使用，脚本入口也会复用）
CODEX_BIN=
CODEX_MODEL=

# OpenCode Server（兼容原版）
OPENCODE_BASE_URL=
OPENCODE_USERNAME=
OPENCODE_PASSWORD=
OPENCODE_MODEL=
OPENCODE_MESSAGE_TIMEOUT=3600

# Google Analytics 4（用于 ga4_metrics.py）
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Kit / ConvertKit（用于 kit_metrics.py 和 newsletter 发布）
KIT_API_KEY=

# Typefully posting（用于 typefully_post.py）
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=12345

# Typefully metrics（用于 typefully_metrics.py，需从浏览器抓取）
TYPEFULLY_AUTHORIZATION=
TYPEFULLY_ACCOUNT=
TYPEFULLY_SESSION=

# Gemini（用于 slides workflow；图片生成请按 docs/SKILL_ECOSYSTEM.md 安装 image-generation-skill）
GEMINI_API_KEY=
GOOGLE_API_KEY=

# 图片生成 public skill repo 可选模型覆盖
IMAGE_GENERATION_MODEL=
GEMINI_FLASH_IMAGE_MODEL=
GEMINI_PRO_IMAGE_MODEL=
GEMINI_IMAGE_GENERATION_MODEL=
GEMINI_IMAGE_UPSCALE_MODEL=
OPENAI_IMAGE_MODEL=

# OpenAI（用于 semantic_search 本地 embedding）
OPENAI_API_KEY=
